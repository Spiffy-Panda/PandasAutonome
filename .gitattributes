# Enforce LF line endings for all text files
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.ogg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.dll binary
*.exe binary
*.pdb binary
*.so binary
*.dylib binary

# Godot binary resources
*.import binary
*.tres binary
*.res binary
