{
  "id": "buy_food",
  "displayName": "Buy Food",
  "category": "trade",
  "requirements": {
    "embodied": true,
    "propertyMin": { "gold": 2 },
    "propertyBelow": { "trade_goods_food": 5 },
    "locationPropertyMin": { "food_supply": 1 }
  },
  "propertyResponses": {
    "trade_goods_food": { "curve": "inverse_linear", "magnitude": 1.0 },
    "mood": { "curve": "constant", "magnitude": 0.2 }
  },
  "personalityAffinity": {
    "diligence": 1.2,
    "frugality": 1.3
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:farm" },
    { "type": "wait", "duration": 2 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": -2 },
    { "type": "modifyProperty", "entity": "location:current", "property": "gold", "amount": 2 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_food", "amount": 1 },
    { "type": "modifyProperty", "entity": "location:current", "property": "food_supply", "amount": -1 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.02 },
    { "type": "emitEvent", "event": "bought_food" }
  ],
  "flavor": {
    "onStart": ["{name} heads to the farmlands to buy provisions."],
    "onComplete": ["{name} loads up a crate of fresh produce."]
  },
  "memoryGeneration": {
    "actionBonus": { "sell_food": 0.15, "trade_goods": 0.1 },
    "decayRate": 0,
    "intensity": 0.2,
    "duration": 48,
    "flavor": "Has food goods to sell",
    "stackMode": "accumulate",
    "maxIntensity": 0.8
  }
