{
  "id": "bake_bread",
  "displayName": "Bake Bread",
  "category": "work",
  "requirements": {
    "embodied": true,
    "propertyMin": { "trade_goods_food": 1 }
  },
  "propertyResponses": {
    "mood": { "curve": "constant", "magnitude": 0.3 },
    "gold": { "curve": "linear", "magnitude": 0.2 }
  },
  "personalityAffinity": {
    "diligence": 1.5,
    "frugality": 1.2,
    "empathy": 1.1
  },
  "steps": [
    { "type": "moveTo", "target": "city.market.square" },
    { "type": "wait", "duration": 8 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.10 },
    { "type": "modifyProperty", "entity": "self", "property": "hunger", "amount": -0.10 },
    { "type": "modifyProperty", "entity": "self", "property": "mood", "amount": 0.1 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_food", "amount": -1 },
    { "type": "modifyProperty", "entity": "location:current", "property": "food_supply", "amount": 1 },
    { "type": "emitEvent", "event": "baked_bread" }
  ],
  "flavor": {
    "onStart": ["{name} stokes the oven before dawn."],
    "onComplete": ["{name} sets the fresh loaves out to cool."]
  }
}
