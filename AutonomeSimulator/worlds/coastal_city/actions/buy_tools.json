{
  "id": "buy_tools",
  "displayName": "Buy Tools",
  "category": "trade",
  "requirements": {
    "embodied": true,
    "propertyMin": { "gold": 6 },
    "propertyBelow": { "trade_goods_tools": 5 },
    "locationPropertyMin": { "tool_supply": 1 }
  },
  "propertyResponses": {
    "trade_goods_tools": { "curve": "inverse_linear", "magnitude": 1.0 },
    "mood": { "curve": "constant", "magnitude": 0.2 }
  },
  "personalityAffinity": {
    "diligence": 1.1,
    "sociability": 1.2
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:smithy" },
    { "type": "wait", "duration": 3 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": -6 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_tools", "amount": 1 },
    { "type": "modifyProperty", "entity": "location:current", "property": "tool_supply", "amount": -1 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.02 },
    { "type": "emitEvent", "event": "bought_tools" }
  ],
  "flavor": {
    "onStart": ["{name} visits the smith to stock up on tools."],
    "onComplete": ["{name} wraps the new tools carefully for transport."]
  },
  "memoryGeneration": {
    "actionBonus": { "sell_tools": 0.15, "trade_goods": 0.1 },
    "decayRate": 0,
    "intensity": 0.2,
    "duration": 48,
    "flavor": "Has tools to sell at market",
    "stackMode": "accumulate",
    "maxIntensity": 0.8
  }
}
