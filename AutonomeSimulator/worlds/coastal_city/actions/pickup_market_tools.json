{
  "id": "pickup_market_tools",
  "displayName": "Pick Up Tools at Market",
  "category": "hauling",
  "requirements": {
    "embodied": true,
    "propertyBelow": { "trade_goods_tools": 7 }
  },
  "propertyResponses": {
    "trade_goods_tools": { "curve": "inverse_linear", "magnitude": 0.35 },
    "mood": { "curve": "constant", "magnitude": 0.15 }
  },
  "personalityAffinity": {
    "diligence": 1.3,
    "frugality": 1.1
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:market" },
    { "type": "wait", "duration": 2 },
    { "type": "modifyProperty", "entity": "location:current", "property": "tool_supply", "amount": -3 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_tools", "amount": 3 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.05 },
    { "type": "emitEvent", "event": "picked_up_tools" }
  ],
  "flavor": {
    "onStart": ["{name} heads to the market to collect tools for export."],
    "onComplete": ["{name} wraps hammers and blades for the long haul to harbor."]
  },
  "memoryGeneration": {
    "actionBonus": { "deliver_tools_harbor": 0.20 },
    "decayRate": 0,
    "intensity": 0.3,
    "duration": 48,
    "flavor": "Tools loaded, harbor bound",
    "stackMode": "accumulate",
    "maxIntensity": 0.8
  }
}
