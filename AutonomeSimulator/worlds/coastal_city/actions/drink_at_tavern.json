{
  "id": "drink_at_tavern",
  "displayName": "Drink at Tavern",
  "category": "social",
  "requirements": {
    "embodied": true,
    "propertyMin": { "gold": 2 }
  },
  "propertyResponses": {
    "social": { "curve": "bell_mid", "magnitude": 0.4 },
    "mood": { "curve": "linear", "magnitude": 0.35 }
  },
  "personalityAffinity": {
    "sociability": 1.3,
    "frugality": 0.7,
    "impulsiveness": 1.2
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:tavern" },
    { "type": "wait", "duration": 2 },
    { "type": "modifyProperty", "entity": "self", "property": "social", "amount": 0.3 },
    { "type": "modifyProperty", "entity": "self", "property": "mood", "amount": 0.25 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": -2 },
    { "type": "emitEvent", "event": "drank_at_tavern" }
  ],
  "flavor": {
    "onStart": ["{name} heads to the tavern for a drink."],
    "onComplete": ["{name} sets down an empty mug."]
  }
}
