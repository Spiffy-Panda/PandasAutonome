{
  "id": "eat_together",
  "displayName": "Eat Together",
  "category": "sustenance",
  "requirements": {
    "embodied": true,
    "propertyMin": { "gold": 2 },
    "nearbyFamily": true
  },
  "propertyResponses": {
    "hunger": { "curve": "desperate", "magnitude": 0.5 },
    "social": { "curve": "linear", "magnitude": 0.3 },
    "mood": { "curve": "smooth_step", "magnitude": 0.2 }
  },
  "personalityAffinity": {
    "sociability": 1.2,
    "empathy": 1.3,
    "frugality": 0.8
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:tavern" },
    { "type": "wait", "duration": 6 },
    { "type": "modifyProperty", "entity": "self", "property": "hunger", "amount": 0.45 },
    { "type": "modifyProperty", "entity": "self", "property": "social", "amount": 0.20 },
    { "type": "modifyProperty", "entity": "self", "property": "mood", "amount": 0.15 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": -4 },
    { "type": "modifyProperty", "entity": "location:current", "property": "gold", "amount": 4 },
    { "type": "modifyProperty", "entity": "location:current", "property": "food_supply", "amount": -2 },
    { "type": "socialInteraction", "targetEntity": "nearbyFamily", "relationshipProperties": { "affinity": 0.08, "familiarity": 0.03, "trust": 0.03 }, "propagateModifiers": true },
    { "type": "emitEvent", "event": "ate_together" }
  ],
  "flavor": {
    "onStart": ["{name} sits down with family for a meal."],
    "onComplete": ["{name} finishes a warm meal with loved ones."]
  }
}
