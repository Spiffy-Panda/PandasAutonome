{
  "id": "buy_ore",
  "displayName": "Buy Ore",
  "category": "trade",
  "requirements": {
    "embodied": true,
    "propertyMin": { "gold": 4 },
    "propertyBelow": { "trade_goods_ore": 5 },
    "locationPropertyMin": { "ore_supply": 1 }
  },
  "propertyResponses": {
    "trade_goods_ore": { "curve": "inverse_linear", "magnitude": 1.0 },
    "mood": { "curve": "constant", "magnitude": 0.2 }
  },
  "personalityAffinity": {
    "diligence": 1.2,
    "frugality": 1.2
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:mine" },
    { "type": "wait", "duration": 3 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": -4 },
    { "type": "modifyProperty", "entity": "location:current", "property": "gold", "amount": 4 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_ore", "amount": 1 },
    { "type": "modifyProperty", "entity": "location:current", "property": "ore_supply", "amount": -1 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.02 },
    { "type": "emitEvent", "event": "bought_ore" }
  ],
  "flavor": {
    "onStart": ["{name} makes for the mines to purchase raw ore."],
    "onComplete": ["{name} secures a load of ore for resale."]
  },
  "memoryGeneration": {
    "actionBonus": { "sell_ore": 0.15, "trade_goods": 0.1 },
    "decayRate": 0,
    "intensity": 0.2,
    "duration": 48,
    "flavor": "Has raw ore ready for resale",
    "stackMode": "accumulate",
    "maxIntensity": 0.8
  }
