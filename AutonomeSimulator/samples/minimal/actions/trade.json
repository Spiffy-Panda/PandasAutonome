    "diligence": 1.3,
    "frugality": 0.8
  },
  "steps": [
    { "type": "wait", "duration": 12 },
    { "type": "modifyProperty", "entity": "self", "property": "gold", "amount": 8 },
    { "type": "modifyProperty", "entity": "self", "property": "mood", "amount": 0.2 },
    { "type": "modifyProperty", "entity": "self", "property": "social", "amount": 0.15 },
    { "type": "emitEvent", "event": "traded_goods" }
  ],
  "flavor": {
    "onStart": ["{name} sets up shop to trade."],
    "onComplete": ["{name} counts the day's earnings."]
