{
  "id": "harvest",
  "displayName": "Harvest Crops",
  "category": "work",
  "requirements": {
    "embodied": true
  },
  "propertyResponses": {
    "mood": { "curve": "constant", "magnitude": 0.25 },
    "hunger": { "curve": "smooth_step", "magnitude": 0.15 }
  },
  "personalityAffinity": {
    "diligence": 1.3,
    "adventurousness": 0.8
  },
  "steps": [
    { "type": "moveTo", "target": "nearestTagged:farm" },
    { "type": "wait", "duration": 15 },
    { "type": "modifyProperty", "entity": "self", "property": "rest", "amount": -0.2 },
    { "type": "modifyProperty", "entity": "self", "property": "hunger", "amount": -0.1 },
    { "type": "modifyProperty", "entity": "self", "property": "mood", "amount": 0.15 },
    { "type": "modifyProperty", "entity": "self", "property": "trade_goods_food", "amount": 1 },
    { "type": "emitEvent", "event": "harvested" }
  ],
  "flavor": {
    "onStart": ["{name} grabs a sickle and heads for the ripe rows."],
    "onComplete": ["{name} loads the last bushel onto the cart."]
  }
}
